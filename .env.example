# ============================================================
# Multi-Agent Platform -- Single Environment File
# Copy to .env in the repo root: Copy-Item .env.example .env (PowerShell)
# All services (agents backend, frontend, docker-compose) read from this file.
# ============================================================

# --- GAS <-> Python secrets ---
WEBHOOK_SECRET=change-me-webhook
GAS_WEBAPP_SECRET=change-me-gas-callback
GAS_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_CLASSIFICATION_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_OCR_MODEL=gpt-4o
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=multi-agent-platform

# --- Airtable (PO parser) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PO_TABLE=Customer POs
AIRTABLE_ITEMS_TABLE=PO Items
AIRTABLE_ATTACHMENTS_FIELD=
# Table/view IDs for record URLs (grab from any Airtable record URL in the browser).
# Without these, the token needs schema:read scope to resolve IDs via the metadata API.
AIRTABLE_PO_TABLE_ID=
AIRTABLE_PO_VIEW_ID=
AIRTABLE_ITEMS_TABLE_ID=
AIRTABLE_ITEMS_VIEW_ID=

# --- Supabase / PostgreSQL (Image tagger) ---
DATABASE_URI=

# --- Frontend + image URLs ---
# Base URL of THIS FastAPI service (not the Next.js port). Used by the browser for API calls
# and by the backend to build /uploads/* links. Set to the same origin you open in the browser
# (e.g. http://localhost:8000 locally, or https://your-tunnel.ngrok-free.dev when testing GAS).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional override for persisted /uploads URLs (same role as NEXT_PUBLIC when both point at
# the public API). If set, it wins over NEXT_PUBLIC for new rows. Use when webhooks use ngrok
# but you also keep NEXT_PUBLIC on localhost — then set this to the ngrok https origin.
# API_PUBLIC_BASE_URL=https://xxxx.ngrok-free.dev
API_PUBLIC_BASE_URL=

# --- Runtime ---
LOG_LEVEL=INFO
